# CLIProxyAPI / CPA 地址。用于 cli_proxy_codex 采集器，可以填裸域名或带 /v0/management 的管理端地址。
CPA_ENDPOINT=https://your-cpa-endpoint.example.com

# CLIProxyAPI / CPA Management Key。用于 Authorization: Bearer <key>，真实值不要提交到仓库。
CPA_MANAGEMENT_KEY=your-management-key

# sub2 地址。用于 sub2_codex 采集器，可以填裸域名或带 /api/v1/admin 的管理端地址。
SUB2_ENDPOINT=https://your-sub2-endpoint.example.com

# sub2 Admin API Key。用于请求头 x-api-key，只读取账号列表里的本地 Codex 快照。
SUB2_ADMIN_API_KEY=your-admin-api-key

# OneBot/NapCatQQ 访问令牌。没有开启鉴权时可以留空。
ONEBOT_ACCESS_TOKEN=

# QQ 官方 Bot AppID。当前 QQ 官方 Bot 通道仍是预留配置，未适配时请保持 config 里 qqbot.enabled=false。
QQBOT_APP_ID=your-qqbot-app-id

# QQ 官方 Bot AppSecret。真实密钥只写本地 .env 或运行环境变量。
QQBOT_APP_SECRET=your-qqbot-app-secret

# QQ 官方 Bot 私聊接收人的 OpenID。
QQBOT_OPENID=your-qq-openid
